# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Railway provides this automatically)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Your production URL (e.g. https://your-app.railway.app)
NEXTAUTH_URL="http://localhost:3000"
# Generate a secret: run `openssl rand -base64 32` in your terminal
NEXTAUTH_SECRET="your-secret-here"

# ─── Resend (Email) ───────────────────────────────────────────────────────────
# Sign up free at https://resend.com — free tier: 3,000 emails/month
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Must match a verified domain/email in your Resend account
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# ─── Twilio (SMS) ─────────────────────────────────────────────────────────────
# Sign up at https://twilio.com — free trial credits included
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+15551234567"

# ─── Stripe (Payments) ────────────────────────────────────────────────────────
# Sign up at https://stripe.com — test mode is free
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Webhook secret — set this after creating your webhook in Stripe dashboard
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Google Places API (Vendor Search) ───────────────────────────────────────
# Required for the venue/vendor search feature in the planning tool.
# Get your key at https://console.cloud.google.com
# Enable: "Places API (New)" in your Google Cloud project
# Free tier includes $200/month of usage (covers ~1,000+ searches)
GOOGLE_PLACES_API_KEY="AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
